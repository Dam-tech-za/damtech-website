{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "dam-tech.co.za" }],
      "destination": "https://www.dam-tech.co.za/",
      "permanent": true
    },
    {
      "source": "/:path((?!_next/).+)",
      "has": [{ "type": "host", "value": "dam-tech.co.za" }],
      "destination": "https://www.dam-tech.co.za/:path/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "damtech-website-six.vercel.app" }],
      "destination": "https://www.dam-tech.co.za/",
      "permanent": true
    },
    {
      "source": "/:path((?!_next/).+)",
      "has": [{ "type": "host", "value": "damtech-website-six.vercel.app" }],
      "destination": "https://www.dam-tech.co.za/:path/",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expire-quotes",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/quote-reminders",
      "schedule": "30 4 * * *"
    }
  ]
}
