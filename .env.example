# =============================================================================
# Damtech Website — environment variables
# Copy to `.env.local` for local development. Never commit real secrets.
# =============================================================================

# --- Supabase (public website leads + admin portal) --------------------------
# Browser-safe (required for admin Google OAuth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Legacy aliases also supported by lib/supabase/env.ts:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Upstash Redis (optional distributed rate limits) ------------------------
# Public RFQs fall back to Supabase RPC when Upstash is missing.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
# HMAC salt for hashed rate-limit keys (recommended in production)
# RATE_LIMIT_HASH_SECRET=generate_a_long_random_secret

# --- Resend (public contact / quote forms + customer quotations) -----------
RESEND_API_KEY=re_your_resend_api_key
# Preferred RFQ names (aliases below still work)
# RFQ_FROM_EMAIL=quote@dam-tech.co.za
# RFQ_REPLY_TO_EMAIL=info@dam-tech.co.za
# RFQ_INTERNAL_NOTIFICATION_EMAIL=info@dam-tech.co.za
# LEAD_INBOX_EMAIL=info@dam-tech.co.za
# CONTACT_FROM_EMAIL=contact@dam-tech.co.za
# QUOTE_FROM_EMAIL=quote@dam-tech.co.za
# QUOTE_REPLY_TO_EMAIL=info@dam-tech.co.za
# QUOTE_INTERNAL_NOTIFY_EMAIL=info@dam-tech.co.za

# --- Cron (Vercel Cron Authorization: Bearer CRON_SECRET) -------------------
# CRON_SECRET=generate_a_long_random_secret

# --- Site URL ----------------------------------------------------------------
# Canonical www origin for metadata, sitemap, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://www.dam-tech.co.za

# --- RFQ diagnostics (Preview only; never leave true in Production) ---------
# RFQ_DEBUG_LOGGING=false

# --- Analytics (optional overrides) ------------------------------------------
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_GTM_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
