# Supabase — server-side only (never expose SERVICE_ROLE_KEY to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional fallback if RLS insert policy is configured on the leads table
# SUPABASE_ANON_KEY=your-anon-key

# Resend — transactional email for contact and quote forms (server-side only)
RESEND_API_KEY=re_your_resend_api_key
# Optional overrides (defaults match dam-tech.co.za production addresses)
# LEAD_INBOX_EMAIL=info@dam-tech.co.za
# CONTACT_FROM_EMAIL=contact@dam-tech.co.za
# QUOTE_FROM_EMAIL=quote@dam-tech.co.za

# Canonical site URL (non-www). Used for metadataBase, canonicals, sitemap, and JSON-LD.
# Set to https://dam-tech.co.za in Vercel Production after connecting the custom domain.
NEXT_PUBLIC_SITE_URL=https://dam-tech.co.za
